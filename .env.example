PORT=3840
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=tulkka

# Postgres (raw.zoom_webhook_request → llm_intake_queue → llm_responses.parsed_response)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# LLM for teacher summary — Gemini only (Google Generative Language API)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Demo UI: leave this empty to avoid any Bearer token requirement.
# (If you set it, API endpoints will require `Authorization: Bearer <INTERNAL_API_SECRET>`.)
INTERNAL_API_SECRET=

# Summary regeneration TTL (days)
SUMMARY_TTL_DAYS=7

# Fire-and-forget refresh when GET finds stale metrics (seconds)
METRICS_STALE_AFTER_SEC=900
